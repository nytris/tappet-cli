{
  "compilerOptions": {
    "declaration": true,
    "esModuleInterop": true,
    "module": "Node16",
    "moduleResolution": "Node16",
    "outDir": "./dist",
    "rewriteRelativeImportExtensions": true,
    "rootDir": ".",
    "sourceMap": true,
    "strict": true,
    "target": "es2020",
    "typeRoots": ["./node_modules/@types"]
  },
  "references": [
    { "path": "./src" },
    { "path": "./bin" }
  ]
}
